PORT=3002
DATABASE_PATH=./data/app.db
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
AUTH_EXPOSE_VERIFY_CODE=false

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_USER=your_account@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="AI TODO <your_account@example.com>"
SMTP_VERIFY_SUBJECT=【AI TODO】邮箱验证码

# TAPD
TAPD_API_USER=your_tapd_user
TAPD_API_TOKEN=replace-with-tapd-token

# Production CORS example when using a custom domain
# CORS_ORIGINS=https://example.com,https://www.example.com
