PORT=3002
DATABASE_PATH=./data/app.db
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
AUTH_EXPOSE_VERIFY_CODE=false

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_USER=your_account@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="AI TODO <your_account@example.com>"
SMTP_VERIFY_SUBJECT=【AI TODO】邮箱验证码

# TAPD
TAPD_API_USER=your_tapd_user
TAPD_API_TOKEN=replace-with-tapd-token

# AI Report
AI_REPORT_PROVIDER=iflow
AI_REPORT_IFLOW_LOG_LEVEL=ERROR
AI_REPORT_IFLOW_AUTOSTART=true
AI_REPORT_IFLOW_TIMEOUT_MS=300000
AI_REPORT_OPENAI_API_KEY=
AI_REPORT_OPENAI_MODEL=gpt-5-mini
AI_REPORT_OPENAI_API_MODE=responses
AI_REPORT_OPENAI_BASE_URL=https://api.openai.com/v1
AI_REPORT_OPENAI_TIMEOUT_MS=300000

# WeChat Mini Program
WECHAT_MINIAPP_APP_ID=your_wechat_miniapp_appid
WECHAT_MINIAPP_APP_SECRET=your_wechat_miniapp_app_secret
WECHAT_MINIAPP_JSCODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
# local test only; do not enable in production
MINIAPP_WECHAT_MOCK_ENABLED=false

# Production CORS example when using a custom domain
# CORS_ORIGINS=https://example.com,https://www.example.com

# OpenClaw
OPENCLAW_PUBLIC_BASE_URL=http://127.0.0.1:3002/api/v1
OPENCLAW_PLUGIN_WS_URL=ws://127.0.0.1:3002/api/v1/openclaw/ws
OPENCLAW_PLUGIN_PACKAGE_NAME=@ld0809/openclaw-channel-aitodo
OPENCLAW_PLUGIN_INSTALL_COMMAND_TEMPLATE=openclaw plugins install {{pluginPackageName}}
OPENCLAW_PLUGIN_ENABLE_COMMAND_TEMPLATE=openclaw config set channels.aitodo '{"enabled":true,"url":"{{wsUrl}}","token":"{{token}}","deviceName":"{{deviceLabel}}"}' --strict-json
