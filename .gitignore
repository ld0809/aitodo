.omc
# Keep the project knowledge base trackable even if a developer has a global docs ignore.
!docs/
docs/*
!docs/PROJECT_KNOWLEDGE.md
!docs/KNOWLEDGE_MAINTENANCE.md
backend/.env
backend/.env.*
!backend/.env.example
client/.env
client/.env.*
!client/.env.example
!client/.env.production.example
client/.vite/
backend/data/backups/
backend/data/*.db
backend/data/*.sqlite
