<view class="container">
  <custom-nav title="邮箱登录 / 注册" subtitle="先完成邮箱账号，再继续绑定小程序账号" />

  <view class="panel auth-panel">
    <view class="tabs">
      <view class="tab {{mode === 'login' ? 'tab-active' : ''}}" data-mode="login" bindtap="switchMode">登录</view>
      <view class="tab {{mode === 'register' ? 'tab-active' : ''}}" data-mode="register" bindtap="switchMode">注册</view>
    </view>

    <view class="field">
      <view class="label">邮箱</view>
      <input class="field-input" value="{{email}}" bindinput="onEmailInput" placeholder="请输入邮箱" />
    </view>

    <view class="field">
      <view class="label">密码</view>
      <input class="field-input" password value="{{password}}" bindinput="onPasswordInput" placeholder="请输入密码" />
    </view>

    <view wx:if="{{mode === 'register' && registerStep === 'verify'}}" class="field">
      <view class="label">验证码</view>
      <view class="verify-row">
        <input class="field-input verify-input" value="{{code}}" bindinput="onCodeInput" placeholder="6位验证码" />
        <button class="btn-secondary resend-btn" bindtap="handleResendCode" loading="{{loadingResend}}">重发</button>
      </view>
    </view>

    <view class="error" wx:if="{{errorMessage}}">{{errorMessage}}</view>

    <button wx:if="{{mode === 'login'}}" class="btn-primary" bindtap="handleLogin" loading="{{loadingSubmit}}">登录</button>

    <block wx:if="{{mode === 'register'}}">
      <button wx:if="{{registerStep === 'form'}}" class="btn-primary" bindtap="handleRegister" loading="{{loadingSubmit}}">注册并发送验证码</button>
      <button wx:if="{{registerStep === 'verify'}}" class="btn-primary" bindtap="handleVerify" loading="{{loadingSubmit}}">验证并继续</button>
    </block>

    <view class="hint">完成邮箱账号后会进入小程序绑定步骤</view>
  </view>
</view>
