.page {
  position: relative;
  height: 100vh;
  min-height: 100vh;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.nav-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(31, 42, 55, 0.08);
}

.tag-row {
  margin: 16rpx 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  flex: none;
}

.tag-indicator {
  color: #607089;
  font-size: 24rpx;
  min-width: 0;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

.filter-label {
  margin-right: 12rpx;
  color: #607089;
  font-size: 22rpx;
  line-height: 1.4;
}

.todo-list {
  flex: 1;
  min-height: 0;
}

.todo-list-content {
  min-height: 100%;
  box-sizing: border-box;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.loading,
.empty {
  padding: 28rpx;
  text-align: center;
  color: #607089;
}

.todo-swipe-row {
  position: relative;
  margin-bottom: 16rpx;
  overflow: hidden;
  border-radius: 20rpx;
}

.todo-swipe-action-bar {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 192rpx;
  display: flex;
  align-items: stretch;
  justify-content: flex-end;
}

.todo-calendar-action {
  width: 192rpx;
  background: #2f7af8;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.todo-calendar-action-disabled {
  background: #cbd5e1;
  color: #475569;
}

.todo-item {
  position: relative;
  z-index: 2;
  padding: 20rpx;
  margin-bottom: 0;
  transition: transform 0.18s ease;
}

.todo-main {
  display: flex;
  align-items: center;
}

.todo-checkbox {
  margin-right: 14rpx;
}

.todo-content {
  flex: 1;
}

.todo-done {
  text-decoration: line-through;
  color: #9aa8bc;
}

.todo-meta {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  color: #607089;
  font-size: 22rpx;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(52rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  flex: none;
  border-radius: 48rpx;
  background: #2f7af8;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 30rpx rgba(47, 122, 248, 0.35);
}

.fab-icon {
  font-size: 52rpx;
  line-height: 1;
}

.drawer-mask,
.sheet-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.28);
  z-index: 80;
}

.drawer {
  position: fixed;
  left: -520rpx;
  top: 0;
  width: 520rpx;
  height: 100vh;
  background: #ffffff;
  z-index: 81;
  transition: left 0.22s ease;
  box-sizing: border-box;
}

.drawer-open {
  left: 0;
}

.drawer-content {
  height: 100%;
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
}

.drawer-toolbar {
  display: flex;
  align-items: center;
}

.nickname {
  font-weight: 600;
}

.drawer-actions {
  margin-left: auto;
  display: flex;
  justify-content: flex-end;
  flex: none;
}

.sync-icon-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #607089;
  flex: none;
}

.sync-icon-btn-disabled {
  opacity: 0.55;
}

.sync-icon {
  font-size: 34rpx;
  line-height: 1;
}

.tag-list {
  margin-top: 18rpx;
}

.tag-item {
  padding: 20rpx 14rpx;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  background: #f7faff;
}

.tag-active {
  background: #e7f0ff;
  color: #2f7af8;
  font-weight: 600;
}

.tag-dragging {
  opacity: 0.7;
  border: 1px dashed #2f7af8;
}

.sync-sheet {
  position: fixed;
  left: 0;
  bottom: -420rpx;
  width: 100vw;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 90;
  padding: 28rpx;
  box-sizing: border-box;
  transition: bottom 0.24s ease;
}

.sync-sheet-open {
  bottom: 0;
}

.sheet-title {
  font-weight: 700;
  margin-bottom: 16rpx;
}

.sheet-item {
  margin-bottom: 8rpx;
  color: #334155;
}

.sheet-message {
  margin: 18rpx 0 24rpx;
  color: #8a5a00;
  font-size: 24rpx;
  line-height: 1.5;
  background: #fff7e6;
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
}

.sheet-pending-title {
  margin-top: 12rpx;
  color: #1e293b;
  font-weight: 600;
  line-height: 1.5;
}
