page {
  background: #f4f8ff;
  color: #1f2a37;
  font-size: 28rpx;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}

button::after {
  border: none;
}

.btn-primary {
  background: #2f7af8;
  color: #ffffff;
  border-radius: 16rpx;
}

.btn-secondary {
  background: #ffffff;
  color: #2f7af8;
  border: 1px solid #2f7af8;
  border-radius: 16rpx;
}

.panel {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 55, 0.08);
}
