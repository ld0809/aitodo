.nav-shell {
  width: 100%;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-side {
  display: flex;
  align-items: center;
  min-width: 88rpx;
}

.nav-side-right {
  justify-content: flex-end;
}

.nav-center {
  flex: 1;
  min-width: 0;
  padding: 0 20rpx;
  text-align: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2a37;
  line-height: 1.3;
}

.nav-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #607089;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(31, 42, 55, 0.08);
}

.icon-text {
  font-size: 42rpx;
  line-height: 1;
  color: #1f2a37;
}
